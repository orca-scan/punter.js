{
  "name": "punter.js",
  "version": "1.3.0",
  "description": "A simple 2D game engine for the web",
  "main": "src/punter.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "http-server . -p 4000 -o",
    "lint": "eslint src/ tests/",
    "test": "NODE_ENV=test TZ=UTC jasmine --config=tests/jasmine/config.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orca-scan/punter.js.git"
  },
  "keywords": [
    "game-engine",
