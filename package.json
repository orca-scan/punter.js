{
  "name": "punter.js",
  "version": "1.2.2",
  "description": "A simple, dependency-free 2D game engine for the browser. No build step, no frameworks - just one script tag.",
  "main": "src/punter.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "npx serve .",
    "start:pong": "npx serve . -l 4000 & npx open-cli http://localhost:4000/games/pong.html",
    "lint": "eslint src/ tests/",
    "test": "NODE_ENV=test TZ=UTC jasmine --config=tests/jasmine/config.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orca-scan/punter.js.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/orca-scan/punter.js/issues"
  },
  "homepage": "https://github.com/orca-scan/punter.js#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jasmine": "^5.13.0",
    "jasmine-console-reporter": "^3.1.0",
    "jasmine-xml-reporter": "^1.2.1",
    "puppeteer": "^25.3.0"
  }
}
