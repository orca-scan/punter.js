    "sprite",
    "game-loop",
    "no-dependencies",
    "lightweight",
    "vanilla-javascript"
  ],
  "author": "Orca Scan <support@orcascan.com> (https://orcascan.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/orca-scan/punter.js/issues"
  },
  "homepage": "https://github.com/orca-scan/punter.js#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "eslint": "^8.57.0",
    "jasmine": "^5.13.0",
    "jasmine-console-reporter": "^3.1.0",
    "jasmine-xml-reporter": "^1.2.1",
    "puppeteer": "^25.3.0"
  }
}